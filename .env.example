# Application
PORT=3000
NODE_ENV=development

# MongoDB (subtask-02)
MONGODB_URI=mongodb://localhost:27017/trendhawk

# LLM Provider — set to 'openai' | 'anthropic' | 'google' (subtask-03)
LLM_PROVIDER=openai

# OpenAI (subtask-03)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (subtask-03)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Google Generative AI (subtask-03)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
GOOGLE_EMBEDDING_MODEL=text-embedding-004
GOOGLE_MODEL=gemini-2.0-flash

# LangSmith tracing (subtask-03, optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=trendhawk
