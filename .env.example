# Application
PORT=3000
NODE_ENV=development

# MongoDB (subtask-02)
MONGODB_URI=mongodb://localhost:27017/trendhawk

# LLM Provider — set to 'openai' | 'anthropic' | 'google' (subtask-03)
LLM_PROVIDER=openai

# OpenAI (subtask-03)
OPENAI_API_KEY=

# Anthropic (subtask-03)
ANTHROPIC_API_KEY=

# Google Generative AI (subtask-03)
GOOGLE_API_KEY=

# LangSmith tracing (subtask-03, optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=trendhawk
